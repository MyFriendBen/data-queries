# Copy this file to terraform.tfvars and update with your values

# Database Configuration
database_host = "host.docker.internal"
database_name = "mfb"
database_port = 5432

# Global Dashboard Database Credentials (Admin Access)
global_db_credentials = {
  username = "mfb"           # Your admin database user
  password = "your_password" # Your admin database password
}

# Tenant-Specific Database Credentials (RLS Users)
# Role names still follow wl_<state>_<id>_ro convention for GRANTs/audit, but
# RLS now uses the session GUC app.white_label_id (set via JDBC options) instead
# of extracting the ID from the role name.
tenant_db_credentials = {
  nc = {
    username = "wl_nc_5_ro"
    password = "your_password"
  }
  co = {
    username = "wl_co_1_ro"
    password = "your_password"
  }
  tx = {
    username = "wl_tx_40_ro"
    password = "your_password"
  }
  wa = {
    username = "wl_wa_41_ro"
    password = "your_password"
  }
  il = {
    username = "wl_il_39_ro"
    password = "your_password"
  }
  ma = {
    username = "wl_ma_38_ro"
    password = "your_password"
  }
  cesn = {
    username = "wl_cesn_4_ro"
    password = "your_password"
  }
  co_tax_calculator = {
    username = "wl_co_tax_calculator_3_ro"
    password = "your_password"
  }
}

# Tenant Configuration (Non-sensitive)
# white_label_id must match the screener_whitelabel.id in the Django database.
# It is passed to Metabase via JDBC options (-c app.white_label_id=<id>) so the
# STABLE RLS function can use an index scan instead of a sequential scan.
tenants = {
  nc = {
    name           = "nc"
    display_name   = "North Carolina"
    white_label_id = 5
  }
  co = {
    name           = "co"
    display_name   = "Colorado"
    white_label_id = 1
  }
  tx = {
    name           = "tx"
    display_name   = "Texas"
    white_label_id = 40
  }
  wa = {
    name           = "wa"
    display_name   = "Washington"
    white_label_id = 41
  }
  il = {
    name           = "il"
    display_name   = "Illinois"
    white_label_id = 39
  }
  ma = {
    name           = "ma"
    display_name   = "Massachusetts"
    white_label_id = 38
  }
  cesn = {
    name           = "cesn"
    display_name   = "CESN"
    white_label_id = 4
  }
  co_tax_calculator = {
    name           = "co_tax_calculator"
    display_name   = "CO Tax Calculator"
    white_label_id = 3
  }
}

# Metabase Configuration
metabase_url = "http://localhost:3001"
metabase_admin_email = "admin@yourcompany.com"
metabase_admin_password = "your_admin_password"  # Set during Metabase setup

# BigQuery Configuration
gcp_project_id = "your-gcp-project-id"
bigquery_enabled = true
bigquery_service_account_key_content = "{ ... }"

# BigQuery dataset where dbt analytics marts are materialized (must match dbt profile target dataset)
# Default is "analytics" — only set this if your dbt profile uses a different dataset name
# bigquery_analytics_dataset = "analytics"

# Local development: specify path to service account key file (defaults to ./secrets/bigquerykey.json)
# bigquery_service_account_key_path = "./secrets/bigquerykey.json"

# Production: pass JSON content from secret manager
# bigquery_service_account_key_content = "{ ... }"
# Or via environment variable: export TF_VAR_bigquery_service_account_key_content="$(gcloud secrets versions access latest --secret=bigquery-key)"
